{
  "name": "abap2ui5-selection-screen",
  "private": true,
  "version": "1.0.0",
  "description": "Selection-Screens, Ranges, Filter and Variant Management for abap2UI5.",
  "scripts": {
    "syfixes": "find . -type f -name '*.abap' -exec sed -i -e 's/ RAISE EXCEPTION TYPE cx_sy_itab_line_not_found/ ASSERT 1 = 0/g' {} + ",
    "rename": "abaplint .github/abaplint/rename.json --rename"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abap2UI5-addons/selection-screen.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/abap2UI5-addons/selection-screen/issues"
  },
  "homepage": "https://github.com/abap2UI5-addons/selection-screen#readme",
  "devDependencies": {
    "@abaplint/cli": "^2.119.14",
    "@abaplint/database-sqlite": "^2.11.78",
    "@abaplint/runtime": "^2.13.22",
    "@abaplint/transpiler-cli": "^2.13.22",
    "@types/node": "^22.10.5",
    "npm-check-updates": "^17.1.18"
  }
}
